def _safe_json_loads(txt: str) -> dict:
    try:
        return json.loads(txt)
    except Exception:
        # 尝试从文本中截取 JSON（应对偶发前后有多余字符）
        start = txt.find("{")
        end = txt.rfind("}")
        if start != -1 and end != -1 and end > start:
            return json.loads(txt[start:end+1])
        raise

def qwen_classify(utterance: str, existing_slots: dict | None = None) -> dict:
    base_url = os.getenv("QWEN_BASE_URL", "https://dashscope.aliyuncs.com/compatible-mode/v1")
    model = os.getenv("QWEN_MODEL", "qwen-plus")
    api_key = os.getenv("DASHSCOPE_API_KEY")

    if not api_key:
        return {"supported": False, "initiative_id": None, "confidence": 0.0, "rationale_short": "missing_api_key",
                "slots": {}, "need_clarification": False, "clarifying_questions": []}

    client = OpenAI(api_key=api_key, base_url=base_url)

    system = (
      "You are an intent router for a Medicine Data & AI portal.\n"
      "Given a user request, pick the best matching initiative from the provided list.\n"
      "If none matches, set supported=false and initiative_id=null.\n"
      "You MUST return ONLY valid JSON.\n"
      "Output JSON schema:\n"
      "{\n"
      '  \"supported\": boolean,\n'
      '  \"initiative_id\": string|null,\n'
      '  \"confidence\": number,\n'
      '  \"rationale_short\": string,\n'
      '  \"slots\": {\n'
      '     \"country\": string|null,\n'
      '     \"therapeutic_area\": string|null,\n'
      '     \"phase\": string|null,\n'
      '     \"objective\": string|null,\n'
      '     \"priority\": string|null\n'
      "  },\n"
      '  \"need_clarification\": boolean,\n'
      '  \"clarifying_questions\": string[]\n'
      "}\n"
      "Rules:\n"
      "- confidence is 0-1.\n"
      "- If supported=true but key slots are missing, set need_clarification=true and ask 1-4 concise questions.\n"
      "- If supported=false, need_clarification=false and clarifying_questions=[].\n"
    )

    initiatives_text = "\n".join([f"- {x['id']}: {x['name']} (group: {x['group']})" for x in INITIATIVES])

    existing = existing_slots or {}
    user = (
    f"User request: {utterance}\n\n"
    f"Existing slots (may be partial): {json.dumps(existing, ensure_ascii=False)}\n\n"
    f"Initiatives:\n{initiatives_text}\n\n"
    "Fill missing slots when possible. If still missing, ask clarifying questions.\n"
    "JSON only:"
    )

    # 强制 JSON 输出（若你的模型/SDK不支持会在日志里报错，我们再降级）
    resp = client.chat.completions.create(
        model=model,
        messages=[{"role":"system","content":system},{"role":"user","content":user}],
        temperature=0,
        response_format={"type":"json_object"},
    )
    txt = resp.choices[0].message.content.strip()
    return _safe_json_loads(txt)

@app.get("/api/health")
def health():
    return {"ok": True}

@app.post("/api/triage")
def triage(req: Req):
    cls = qwen_classify(req.utterance, req.slots or {})

    supported = bool(cls.get("supported"))
    iid = cls.get("initiative_id")
    conf = float(cls.get("confidence", 0.2) or 0.2)
    slots = cls.get("slots", {}) or {}
    need = bool(cls.get("need_clarification", False))
    questions = cls.get("clarifying_questions", []) or []

    # unsupported → 记录到需求池日志
    if (not supported) or (not iid):
        ts = datetime.utcnow().isoformat()
        with open("/var/log/lab-unsupported.log", "a", encoding="utf-8") as f:
            f.write(f"{ts}\t{req.utterance.replace(chr(10),' ').replace(chr(9),' ')}\n")

        return {
            "utterance": req.utterance,
            "supported": False,
            "intent": None,
            "confidence": conf,
            "routed_channel": None,
            "initiative": None,
            "slots": slots,
            "need_clarification": False,
            "clarifying_questions": [],
            "execution_plan": [],
            "next_action": "captured_for_analysis",
            "llm": cls,
        }

    meta = next((x for x in INITIATIVES if x["id"] == iid), None)

    if need:
        apps = ["intent_parser", "slot_filler"]
        next_action = "ask_clarifying_questions"
    else:
        apps = PIPELINES.get(iid, ["intent_parser","deliver"])
        next_action = "execute_plan"

    existing_slots = req.slots or {}
    model_slots = cls.get("slots") or {}

    merged_slots = dict(existing_slots)          # 先用已有
    merged_slots.update(model_slots)             # 再用模型覆盖（模型优先）

    return {
        "utterance": req.utterance,
        "supported": True,
        "intent": iid,
        "confidence": conf,
        "routed_channel": meta["group"] if meta else "Unknown",
        "initiative": meta["name"] if meta else iid,
        "slots": merged_slots,
        "need_clarification": need,
        "clarifying_questions": questions,
        "execution_plan": [{"step": i+1, "app": a} for i, a in enumerate(apps)],
        "next_action": next_action,
        "llm": cls,
    }
