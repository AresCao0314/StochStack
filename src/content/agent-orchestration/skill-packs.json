          "Data quality checks",
          "Owner and release target",
          "Validation evidence"
        ]
      }
    }
  },
  {
    "initiativeId": "initiative-10-ai-authoring",
    "inputSchema": [
      { "name": "documentType", "type": "string", "required": true, "description": "Target document type", "example": "Protocol synopsis" },
      { "name": "sourcePackage", "type": "object", "required": true, "description": "Source references and constraints", "example": { "protocol": "v1.2", "styleGuide": "MW-STD-2026" } },
      { "name": "qualityRequirements", "type": "string[]", "required": true, "description": "Quality and compliance requirements", "example": ["traceable citations", "medical review required"] }
    ],
    "tools": [
      { "name": "Authoring Draft Agent", "purpose": "Generate first draft from approved context", "mode": "generation" },
      { "name": "Citation Verifier", "purpose": "Check traceability against source package", "mode": "validation" },
      { "name": "Quality Style Checker", "purpose": "Enforce template, tone, and consistency rules", "mode": "quality" }
    ],
    "approvalGates": [
      { "gate": "Gate A: Source lock", "owner": "Medical Writing Lead", "criteria": "Source package complete and frozen" },
      { "gate": "Gate B: Scientific review", "owner": "Clinical Scientist", "criteria": "Scientific content validated" },
      { "gate": "Gate C: Final quality approval", "owner": "MW QA", "criteria": "Compliance and style checks passed" }
    ],
    "outputTemplates": {
      "email": {
        "subject": "[AI Authoring] {{documentType}} draft ready for review",
        "bodyOutline": [
          "Draft scope and source package used",
          "Open issues requiring reviewer input",
          "Review deadline and owner"
        ]
      },
      "report": {
        "sections": [
          "Input source traceability",
          "Draft output summary",
          "Quality findings",
          "Review decision log"
        ]
      },
      "jira": {
        "summaryTemplate": "[Authoring] Review {{documentType}} draft {{version}}",
        "descriptionChecklist": [
          "Scope and objectives",
          "Citation and evidence checks",
          "Reviewer comments",
          "Approval outcome"
        ]
      }
    }
  }
]
