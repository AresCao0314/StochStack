    "title": "Phase 3 First-line NSCLC Combination Therapy",
    "therapeuticArea": "Oncology",
    "indication": "NSCLC",
    "phase": "Phase 3",
    "summary": "Randomized Phase 3 trial comparing SOC vs investigational combo in first-line metastatic NSCLC.",
    "inclusionCriteria": [
      { "id": "I1", "text": "Age 18-75 years" },
      { "id": "I2", "text": "Histologically confirmed stage IV NSCLC" },
      { "id": "I3", "text": "ECOG performance status 0-1" },
      { "id": "I4", "text": "ANC >= 1.5 x10^9/L, Platelets >= 100 x10^9/L" },
      { "id": "I5", "text": "ALT/AST <= 2.5 x ULN (<=5 x ULN if liver metastases)" },
      { "id": "I6", "text": "Creatinine clearance >= 50 mL/min" }
    ],
    "exclusionCriteria": [
      { "id": "E1", "text": "Untreated or symptomatic CNS metastases" },
      { "id": "E2", "text": "Active uncontrolled infection" },
      { "id": "E3", "text": "Pregnancy or breastfeeding" },
      { "id": "E4", "text": "Prior anti-PD-1/PD-L1 treatment in metastatic setting" }
    ],
    "eligibilityRules": {
      "age": { "min": 18, "max": 75, "evidence": "I1" },
      "ecog": { "max": 1, "evidence": "I3" },
      "ancMin": { "value": 1.5, "evidence": "I4" },
      "plateletsMin": { "value": 100, "evidence": "I4" },
      "altUlnMax": { "value": 2.5, "evidence": "I5" },
      "creatinineClearanceMin": { "value": 50, "evidence": "I6" }
    },
    "medicationRestrictions": [
      {
        "name": "Strong CYP3A4 inhibitors",
        "aliases": ["ketoconazole", "itraconazole", "clarithromycin", "ritonavir"],
        "level": "prohibited",
        "reason": "May significantly increase investigational drug exposure.",
        "evidence": "Section 6.3.1",
        "washoutDays": 14
      },
      {
        "name": "Systemic corticosteroid >10 mg prednisone equivalent",
        "aliases": ["prednisone", "dexamethasone", "methylprednisolone"],
        "level": "caution",
        "reason": "Potential impact on immune-related endpoints.",
        "evidence": "Section 6.3.2",
        "washoutDays": 7
      },
      {
        "name": "Live attenuated vaccines",
        "aliases": ["live vaccine", "MMR", "varicella vaccine"],
        "level": "prohibited",
        "reason": "Immune modulation risk during investigational treatment.",
        "evidence": "Section 6.3.4",
        "washoutDays": 30
      }
    ],
