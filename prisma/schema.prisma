generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Study {
  id         String           @id @default(cuid())
  name       String
  indication String
  phase      String
  createdAt  DateTime         @default(now())
  documents  Document[]
  runs       ExtractionRun[]
  feedback   FeedbackAmendment[]
}

model Document {
  id          String          @id @default(cuid())
  studyId     String
  type        String
  filename    String
  mimeType    String
  versionTag  String
  uploadedAt  DateTime        @default(now())
  textExtract String?
  study       Study           @relation(fields: [studyId], references: [id], onDelete: Cascade)
  runs        ExtractionRun[]
}

model ExtractionRun {
  id            String           @id @default(cuid())
  studyId       String
  documentId    String
  status        String           @default("queued")
  modelName     String
  promptVersion String
  startedAt     DateTime?
  finishedAt    DateTime?
  study         Study            @relation(fields: [studyId], references: [id], onDelete: Cascade)
  document      Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields        ExtractedField[]
  usdmArtifact  USDMArtifact?
  ddfArtifact   DDFArtifact?

  @@index([studyId])
  @@index([documentId])
}

model ExtractedField {
  id            String         @id @default(cuid())
  runId          String
  path           String
  value          String
  confidence     Float
  evidence       String
  reviewerState  String        @default("pending")
  reviewerEdits  String?
  reviewReason   String?
  run            ExtractionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([path])
}

model USDMArtifact {
  id            String        @id @default(cuid())
  runId          String        @unique
  usdmJson       String
  schemaVersion  String
  generatedAt    DateTime      @default(now())
  run            ExtractionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model DDFArtifact {
  id            String        @id @default(cuid())
  runId          String        @unique
  ddfJson        String
  generatedAt    DateTime      @default(now())
  run            ExtractionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model ChangeSet {
  id           String   @id @default(cuid())
  baseRunId    String
  compareRunId String
  summary      String
  changes      String
  generatedAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  entityType String
  entityId   String
  payload    String
  createdAt  DateTime @default(now())
}

model FeedbackAmendment {
  id              String            @id @default(cuid())
  studyId          String
  amendmentDate    DateTime
  category         String
  description      String
  linkedUsdmPaths  String
  createdAt        DateTime          @default(now())
  study            Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([studyId])
}

model User {
  id           String              @id @default(cuid())
  name         String
  email        String              @unique
  globalRole   String              @default("viewer")
  memberships  ProjectMembership[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Project {
  id             String              @id @default(cuid())
  name           String
  indication     String
  phase          String
  status         String              @default("draft")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  brief          Brief?
  evidence       EvidenceSnippet[]
  graphs         DesignGraph[]
  policies       PolicyProfile[]
  logs           ChangeLog[]
  exports        ExportArtifact[]
  memberships    ProjectMembership[]
}

model ProjectMembership {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  role       String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Brief {
  id         String   @id @default(cuid())
  projectId  String   @unique
  fieldsJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EvidenceSnippet {
  id            String   @id @default(cuid())
  projectId      String
  title          String
  text           String
  sourceType     String
  sourceRef      String?
  publishedDate  DateTime?
  tagsJson       Json?
  confidence     Float    @default(0.7)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model DesignGraph {
  id          String         @id @default(cuid())
  projectId   String
  version     Int
  nodesJson   Json
  edgesJson   Json
  createdAt   DateTime       @default(now())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  decisions   DecisionNode[]
  proposals   Proposal[]

  @@unique([projectId, version])
  @@index([projectId])
}

model DecisionNode {
  id                String      @id @default(cuid())
  graphId           String
  key               String
  type              String
  status            String      @default("draft")
  selectedOptionId  String?
  contentJson       Json?
  updatedAt         DateTime    @updatedAt
  graph             DesignGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@index([graphId, key])
}

model Proposal {
  id             String      @id @default(cuid())
  graphId        String
  nodeKey        String
  skillName      String
  planId         String?
  proposalJson   Json
  scoreJson      Json?
  conflictsJson  Json?
  createdAt      DateTime    @default(now())
  graph          DesignGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@index([graphId, nodeKey])
}

model PolicyProfile {
  id         String   @id @default(cuid())
  projectId  String
  role       String
  ownerName  String
  policyJson Json
  weight     Float    @default(1.0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ChangeLog {
  id           String   @id @default(cuid())
  projectId     String
  graphVersion  Int?
  actor         String
  action        String
  payloadJson   Json
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ExportArtifact {
  id          String   @id @default(cuid())
  projectId   String
  type        String
  version     Int
  storageRef  String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
